---
// Override of Starlight's EditLink. Docs are loaded via a glob loader from
// src/content/docs, so we build the GitHub edit URL from the source file path
// (made repo-relative) rather than the default baseUrl computation.
import { Icon } from "@astrojs/starlight/components";

const REPO_EDIT_BASE = "https://github.com/mishachepi/junior/edit/main/";
const DOCS_DIR = "docs-site/src/content/docs/";

const { entry } = Astro.locals.starlightRoute;
const filePath = entry.filePath ?? "";

// Everything after `content/docs/` (handles absolute or relative paths);
// fall back to the route id when the loader doesn't expose a file path.
const match = filePath.match(/content\/docs\/(.*)$/);
let rel = match ? match[1] : `${entry.id || "index"}`;
if (!rel.endsWith(".md")) rel += ".md";

const href = REPO_EDIT_BASE + DOCS_DIR + rel;
const label = Astro.locals.t("page.editLink");
---

<a {href} class="sl-flex">
  <Icon name="pencil" size="1.2em" />
  {label}
</a>

<style>
  a {
    gap: 0.5em;
    align-items: center;
    text-decoration: none;
    color: var(--sl-color-gray-3);
  }
  a:hover {
    color: var(--sl-color-white);
  }
</style>
